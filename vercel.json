{
  "version": 2,
  "framework": null,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "crons": [
    {
      "path": "/api/emails/cron",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/etsy/sync",
      "schedule": "0 15 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/auth/register",
      "destination": "/api/auth/register"
    },
    {
      "source": "/api/auth/login",
      "destination": "/api/auth/login"
    },
    {
      "source": "/api/auth/me",
      "destination": "/api/auth/me"
    },
    {
      "source": "/api/auth/accept",
      "destination": "/api/auth/accept"
    },
    {
      "source": "/api/auth/verify-email",
      "destination": "/api/auth/verify-email"
    },
    {
      "source": "/api/shows/on-this-day",
      "destination": "/api/shows/on-this-day"
    },
    {
      "source": "/api/shows",
      "destination": "/api/shows/index"
    },
    {
      "source": "/api/shows/:date",
      "destination": "/api/shows/[date]"
    },
    {
      "source": "/api/ratings/:showDate",
      "destination": "/api/ratings/[showDate]"
    },
    {
      "source": "/api/user/shows",
      "destination": "/api/user/shows"
    },
    {
      "source": "/api/user/attendance",
      "destination": "/api/user/attendance"
    },
    {
      "source": "/api/user/kpi",
      "destination": "/api/user/kpi"
    },
    {
      "source": "/api/user/profile",
      "destination": "/api/user/profile"
    },
    {
      "source": "/api/user/sync",
      "destination": "/api/user/sync"
    },
    {
      "source": "/api/user/deep-phreeze",
      "destination": "/api/user/deep-phreeze"
    },
    {
      "source": "/api/analytics/songs",
      "destination": "/api/analytics/songs"
    },
    {
      "source": "/api/analytics/venues",
      "destination": "/api/analytics/venues"
    },
    {
      "source": "/api/random-show",
      "destination": "/api/random-show"
    },
    {
      "source": "/api/audio/:date",
      "destination": "/api/audio/[date]"
    },
    {
      "source": "/api/import/phishnet",
      "destination": "/api/import/phishnet"
    },
    {
      "source": "/api/import/phishnet-reviews",
      "destination": "/api/import/phishnet-reviews"
    },
    {
      "source": "/api/admin/users",
      "destination": "/api/admin/users"
    },
    {
      "source": "/api/admin/user",
      "destination": "/api/admin/user"
    },
    {
      "source": "/api/admin/migrate",
      "destination": "/api/admin/migrate"
    },
    {
      "source": "/api/admin/clear-cache",
      "destination": "/api/admin/clear-cache"
    },
    {
      "source": "/api/community/leaderboard",
      "destination": "/api/community/leaderboard"
    },
    {
      "source": "/api/community/user-search",
      "destination": "/api/community/user-search"
    },
    {
      "source": "/api/community/overlap-suggestions",
      "destination": "/api/community/overlap-suggestions"
    },
    {
      "source": "/api/user/profile-options",
      "destination": "/api/user/profile-options"
    },
    {
      "source": "/api/user/companions",
      "destination": "/api/user/companions"
    },
    {
      "source": "/api/feedback/submit",
      "destination": "/api/feedback/submit"
    },
    {
      "source": "/api/admin/feedback",
      "destination": "/api/admin/feedback"
    },
    {
      "source": "/api/ai/summarize",
      "destination": "/api/ai/summarize"
    },
    {
      "source": "/api/ai/ebenezer",
      "destination": "/api/ai/ebenezer"
    },
    {
      "source": "/api/shows/companions",
      "destination": "/api/shows/companions"
    },
    {
      "source": "/api/admin/stats",
      "destination": "/api/admin/stats"
    },
    {
      "source": "/api/emails/onboarding",
      "destination": "/api/emails/onboarding"
    },
    {
      "source": "/api/emails/cron",
      "destination": "/api/emails/cron"
    },
    {
      "source": "/api/admin/ai-usage",
      "destination": "/api/admin/ai-usage"
    },
    {
      "source": "/api/admin/monitoring",
      "destination": "/api/admin/monitoring"
    },
    {
      "source": "/api/admin/health",
      "destination": "/api/admin/health"
    },
    {
      "source": "/api/audio/stream",
      "destination": "/api/audio/stream"
    },
    {
      "source": "/api/admin/donations",
      "destination": "/api/admin/donations"
    },
    {
      "source": "/api/etsy/auth",
      "destination": "/api/etsy/auth"
    },
    {
      "source": "/api/etsy/callback",
      "destination": "/api/etsy/callback"
    },
    {
      "source": "/api/etsy/sync",
      "destination": "/api/etsy/sync"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}