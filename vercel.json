{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/styles.css",
      "dest": "public/styles.css"
    },
    {
      "src": "/app.js",
      "dest": "public/app.js"
    },
    {
      "src": "/auth.js",
      "dest": "public/auth.js"
    },
    {
      "src": "/ui.js",
      "dest": "public/ui.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/index.html"
    }
  ]
}
